{
  "name": "Workday Autofill",
  "description": "Helps students fill out Workday job applications",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "hello.html",
    "default_icon": "extension-logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["extension-logo.png"],
      "matches": ["*://*.myworkdayjobs.com/*"]
    }
  ],
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://*.myworkdayjobs.com/*"],
      "js": ["styles.js", "profile.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}